rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /urls/{shortCode} {
      allow read: if true;
      allow create: if
        request.resource.data.originalUrl is string &&
        request.resource.data.originalUrl.size() > 5 &&
        request.resource.data.clicks == 0 &&
        request.resource.data.active == true;
      allow update: if
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']) &&
         request.resource.data.clicks == resource.data.clicks + 1)
        ||
        (request.resource.data.deviceId == resource.data.deviceId);
      allow delete: if true;

      match /analytics/{id} {
        allow read, create: if true;
        allow update, delete: if false;
      }
    }
  }
}